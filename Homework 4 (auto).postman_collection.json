    {
      "name": "Create Post",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200 OK\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Status code name is OK\", function () {\r",
              "    pm.response.to.have.status(\"OK\");\r",
              "});\r",
              "\r",
              "pm.test(\"Response time is less than 600ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(600);\r",
              "});\r",
              "\r",
              "var jsonData = pm.response.json();\r",
              "\r",
              "pm.test(\"Check id is non-empty string\", function () {\r",
              "    pm.expect(jsonData.id).to.be.a(\"string\").and.not.be.empty;\r",
              "});\r",
              "\r",
              "pm.collectionVariables.set(\"postId\", jsonData.id);\r",
              "\r",
              "pm.test(\"Check tags\", function () {\r",
              "    pm.expect(jsonData.tags).to.be.an(\"array\");\r",
              "    pm.expect(jsonData.tags[0]).to.eql(\"true\");\r",
              "});\r",
              "\r",
              "pm.test(\"Check text\", function () {\r",
              "    pm.expect(jsonData.text).to.eql(\"New post about post\");\r",
              "});\r",
              "\r",
              "pm.test(\"Check image\", function () {\r",
              "    pm.expect(jsonData.image).to.eql(\"http://www.photo.com/image.jpg\");\r",
              "});\r",
              "\r",
              "pm.test(\"Check likes is number\", function () {\r",
              "    pm.expect(jsonData.likes).to.be.a(\"number\");\r",
              "});\r",
              "\r",
              "pm.test(\"Check owner is object with id\", function () {\r",
              "    pm.expect(jsonData.owner).to.be.an(\"object\");\r",
              "    pm.expect(jsonData.owner).to.have.property(\"id\").and.to.be.a(\"string\").and.not.be.empty;\r",
              "    pm.expect(jsonData.owner).to.have.property(\"title\");\r",
              "    pm.expect(jsonData.owner).to.have.property(\"firstName\");\r",
              "    pm.expect(jsonData.owner).to.have.property(\"lastName\");\r",
              "});\r",
              "\r",
              "pm.test(\"Check owner fields\", function () {\r",
              "    pm.expect(jsonData.owner.title).to.eql(\"mr\");\r",
              "    pm.expect(jsonData.owner.firstName).to.eql(\"Jack\");\r",
              "    pm.expect(jsonData.owner.lastName).to.eql(\"Norton\");\r",
              "});\r",
              "\r",
              "pm.test(\"Check publishDate is string\", function () {\r",
              "    pm.expect(jsonData.publishDate).to.be.a(\"string\");\r",
              "});\r",
              "\r",
              "pm.test(\"Check updatedDate is string\", function () {\r",
              "    pm.expect(jsonData.publishDate).to.be.a(\"string\");\r",
              "});\r",
              "\r",
              "\r",
              "\r",
              "\r",
              "\r",
              "\r",
